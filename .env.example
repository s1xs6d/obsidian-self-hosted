# Copy this file to .env and fill in your values.

# Login password. Leave empty to disable authentication.
# Generate a strong value with: openssl rand -hex 32
OSH_TOKEN=enter-your-password-here

# File browser root directory. Defaults to the OS home directory.
# OSH_HOME=/path/to/your/notes

# Server listen address. Defaults to :27123.
# OSH_ADDR=:27123

# Enable terminal access from the Obsidian UI (experimental).
# Set to "true" to show a Terminal button in the status bar that opens a shell.
# OSH_TERMINAL=true
